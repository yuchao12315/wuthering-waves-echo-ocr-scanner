/* pages/characters/characters.wxss */

.page {
  padding: 24rpx;
  background: #18181b;
  min-height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e4e4e7;
}

.count {
  font-size: 22rpx;
  color: #71717a;
}

.search-input {
  margin-left: auto;
  background: #27272a;
  border: 1rpx solid #3f3f46;
  border-radius: 8rpx;
  padding: 8rpx 20rpx;
  font-size: 26rpx;
  color: #d4d4d8;
  width: 260rpx;
}

.placeholder {
  color: #52525b;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #71717a;
}

/* 卡片网格 */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

@media (min-width: 768px) {
  .grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.card {
  background: #18181b;
  border: 1rpx solid #27272a;
  border-radius: 16rpx;
  padding: 20rpx;
  transition: all 0.2s;
}

.card:active {
  background: #27272a;
}

.card-selected {
  border-color: #9333ea;
  background: #27272a;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.char-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #e4e4e7;
}

.tag-row {
  display: flex;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.tag-element {
  color: #e4e4e7;
}

.tag-热熔 { background: #7f1d1d; color: #fca5a5; }
.tag-导电 { background: #4c1d95; color: #c4b5fd; }
.tag-气动 { background: #064e3b; color: #6ee7b7; }
.tag-冷凝 { background: #1e3a5f; color: #93c5fd; }
.tag-湮灭 { background: #3b0764; color: #d8b4fe; }
.tag-衍射 { background: #713f12; color: #fde68a; }

.tag-weapon {
  background: #27272a;
  color: #a1a1aa;
}

/* 权重摘要 */
.sub-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.sub-tag {
  font-size: 20rpx;
  background: #27272a;
  color: #a1a1aa;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

/* 词条分级 */
.grade-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.grade-s {
  font-size: 20rpx;
  background: rgba(127, 29, 29, 0.5);
  color: #fca5a5;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.grade-a {
  font-size: 20rpx;
  background: rgba(113, 63, 18, 0.5);
  color: #fde68a;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}
