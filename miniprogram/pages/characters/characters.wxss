/* pages/characters/characters.wxss */

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
  background: #f4f6fb;
}

.header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e4e9f2;
  border-radius: 12rpx;
  box-shadow: 0 10rpx 28rpx rgba(24, 32, 51, 0.06);
  flex-wrap: wrap;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #182033;
}

.count {
  font-size: 22rpx;
  color: #7a8499;
}

.search-input {
  flex: 1;
  min-width: 260rpx;
  height: 72rpx;
  margin-left: 8rpx;
  background: #f7f9fc;
  border: 1rpx solid #dbe3ef;
  border-radius: 10rpx;
  padding: 0 22rpx;
  font-size: 26rpx;
  color: #182033;
}

.placeholder {
  color: #9aa4b5;
}

.empty {
  text-align: center;
  padding: 96rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #7a8499;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.card {
  width: calc((100% - 18rpx) / 2);
  min-height: 196rpx;
  background: #ffffff;
  border: 1rpx solid #e1e7f0;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 22rpx rgba(24, 32, 51, 0.05);
}

.card:active {
  background: #f8fbff;
}

.card-selected {
  border-color: #2563eb;
  box-shadow: 0 10rpx 28rpx rgba(37, 99, 235, 0.16);
}

.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.char-name {
  max-width: 180rpx;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #182033;
}

.tag-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.tag {
  min-height: 34rpx;
  font-size: 20rpx;
  line-height: 34rpx;
  padding: 0 10rpx;
  border-radius: 6rpx;
  white-space: nowrap;
}

.tag-elem-fire { background: #fee2e2; color: #b42318; }
.tag-elem-electric { background: #ede9fe; color: #5b21b6; }
.tag-elem-wind { background: #dcfce7; color: #166534; }
.tag-elem-ice { background: #dbeafe; color: #1d4ed8; }
.tag-elem-dark { background: #f3e8ff; color: #7e22ce; }
.tag-elem-light { background: #fef3c7; color: #92400e; }

.tag-weapon {
  background: #eef2f7;
  color: #526071;
}

.sub-row,
.grade-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.sub-row {
  margin-bottom: 10rpx;
}

.sub-tag {
  font-size: 20rpx;
  color: #3f4b5f;
  background: #f1f5f9;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.grade-s,
.grade-a {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.grade-s {
  background: #fff1f2;
  color: #be123c;
}

.grade-a {
  background: #ecfdf3;
  color: #15803d;
}
