/* pages/calculator/calculator.wxss */

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 56rpx;
  background: #f4f6fb;
}

.section,
.progress-section,
.filter-warning,
.result-card {
  background: #ffffff;
  border: 1rpx solid #e1e7f0;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 22rpx rgba(24, 32, 51, 0.05);
}

.section {
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.section-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.mt12 { margin-top: 12rpx; }
.mt16 { margin-top: 16rpx; }

.label,
.label-sm {
  font-size: 24rpx;
  color: #667085;
}

.label {
  font-weight: 600;
}

.hint {
  font-size: 22rpx;
  color: #98a2b3;
}

.char-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #182033;
}

.char-name.dim {
  color: #98a2b3;
}

.link,
.clear-link {
  font-size: 24rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
}

.link {
  color: #2563eb;
  background: #eff6ff;
}

.clear-link {
  color: #b42318;
  background: #fff1f2;
}

.quota-tag {
  min-height: 42rpx;
  line-height: 42rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 22rpx;
}

.btn,
.btn-sm,
.sonata-tag,
.exclude-tag,
.picker-btn {
  min-height: 56rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn {
  padding: 0 22rpx;
  font-size: 24rpx;
}

.btn-sm {
  min-width: 56rpx;
  padding: 0 14rpx;
  font-size: 24rpx;
}

.btn-active {
  background: #2563eb;
  color: #ffffff;
}

.btn-inactive,
.btn-dim {
  background: #f1f5f9;
  color: #4b5565;
}

.btn-dim {
  color: #98a2b3;
}

.btn-disabled {
  opacity: 0.45;
}

.picker-btn {
  max-width: 440rpx;
  gap: 10rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  padding: 0 18rpx;
  font-size: 24rpx;
  color: #182033;
}

.arrow {
  font-size: 20rpx;
  color: #7a8499;
}

.refine-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.threshold-group {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 10rpx;
  background: #f8fafc;
  border: 1rpx solid #e4e9f2;
  border-radius: 10rpx;
}

.threshold-label,
.threshold-pct {
  font-size: 22rpx;
  color: #667085;
}

.threshold-input {
  width: 96rpx;
  height: 56rpx;
  background: #ffffff;
  border: 1rpx solid #dbe3ef;
  border-radius: 8rpx;
  padding: 0 10rpx;
  font-size: 24rpx;
  color: #182033;
  text-align: center;
}

.placeholder {
  color: #98a2b3;
}

.sonata-grid,
.exclude-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.sonata-tag,
.exclude-tag {
  padding: 0 16rpx;
  font-size: 23rpx;
}

.sonata-active {
  background: #2563eb;
  color: #ffffff;
}

.sonata-inactive,
.exclude-inactive {
  background: #f1f5f9;
  color: #4b5565;
}

.exclude-active {
  background: #fff1f2;
  color: #b42318;
}

.calc-btn {
  width: 100%;
  min-height: 88rpx;
  margin: 24rpx 0;
  background: #2563eb;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 12rpx 26rpx rgba(37, 99, 235, 0.22);
}

.calc-btn::after {
  border: none;
}

.calc-btn-disabled {
  background: #aab7c8;
  box-shadow: none;
}

.quota-row {
  margin: -12rpx 0 22rpx;
  text-align: center;
  color: #667085;
  font-size: 23rpx;
}

.progress-section {
  padding: 22rpx;
  margin-bottom: 24rpx;
}

.progress-info {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.progress-text {
  font-size: 24rpx;
  color: #4b5565;
}

.progress-time {
  font-size: 24rpx;
  color: #2563eb;
  font-family: monospace;
}

.progress-pct {
  margin-left: auto;
  font-size: 24rpx;
  color: #667085;
}

.progress-bar {
  width: 100%;
  height: 14rpx;
  background: #e8edf5;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #2563eb;
  border-radius: 999rpx;
}

.filter-warning {
  padding: 24rpx;
  margin-bottom: 20rpx;
  color: #b54708;
  background: #fffbeb;
  border-color: #fedf89;
  font-size: 26rpx;
}

.results {
  margin-top: 18rpx;
}

.results-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 8rpx 4rpx 16rpx;
  flex-wrap: wrap;
}

.results-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #182033;
}

.results-sub,
.results-filtered {
  font-size: 23rpx;
  color: #7a8499;
}

.results-tag {
  font-size: 22rpx;
  color: #2563eb;
}

.result-card {
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.result-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
  flex-wrap: wrap;
}

.rank {
  font-size: 30rpx;
  font-weight: 800;
  color: #182033;
}

.score {
  font-size: 26rpx;
  color: #3f4b5f;
}

.grade {
  font-size: 26rpx;
  font-weight: 800;
}

.grade-SSS { color: #be123c; }
.grade-SS { color: #ea580c; }
.grade-S { color: #ca8a04; }
.grade-A { color: #2563eb; }
.grade-B { color: #0891b2; }
.grade-C { color: #7a8499; }

.dmg {
  font-size: 23rpx;
  color: #b54708;
  font-family: monospace;
}

.save-btn {
  margin-left: auto;
  min-height: 52rpx;
  line-height: 52rpx;
  font-size: 23rpx;
  color: #ffffff;
  background: #16a34a;
  padding: 0 18rpx;
  border-radius: 8rpx;
}

.result-stats {
  display: flex;
  gap: 10rpx;
  margin-bottom: 14rpx;
  flex-wrap: wrap;
}

.stat {
  font-size: 22rpx;
  color: #4b5565;
  background: #f1f5f9;
  border-radius: 6rpx;
  padding: 5rpx 10rpx;
  font-family: monospace;
}

.stat-warn {
  color: #b42318;
  background: #fff1f2;
}

.stat.dim {
  color: #7a8499;
}

.echo-scroll {
  white-space: nowrap;
  margin: 0 -22rpx;
  padding: 0 22rpx;
}

.echo-row {
  display: inline-flex;
  gap: 12rpx;
}

.echo-mini {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  min-height: 126rpx;
  padding: 10rpx 6rpx;
  background: #f8fafc;
  border: 1rpx solid #e4e9f2;
  border-radius: 10rpx;
}

.echo-cost {
  font-size: 20rpx;
  font-weight: 700;
  padding: 3rpx 10rpx;
  border-radius: 6rpx;
  margin-bottom: 6rpx;
}

.echo-cost-1 { background: #eef2f7; color: #526071; }
.echo-cost-3 { background: #dbeafe; color: #1d4ed8; }
.echo-cost-4 { background: #ede9fe; color: #5b21b6; }

.echo-name {
  max-width: 112rpx;
  font-size: 20rpx;
  line-height: 1.25;
  color: #182033;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: center;
}

.echo-score {
  margin-top: 4rpx;
  font-size: 19rpx;
  color: #667085;
  font-family: monospace;
}
