/* pages/calculator/calculator.wxss */

.page {
  padding: 24rpx;
  background: #18181b;
  min-height: 100vh;
}

/* 通用 section */
.section {
  margin-bottom: 24rpx;
}

.section-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.mt12 { margin-top: 12rpx; }
.mt16 { margin-top: 16rpx; }

.label {
  font-size: 26rpx;
  color: #a1a1aa;
}

.label-sm {
  font-size: 24rpx;
  color: #71717a;
}

.hint {
  font-size: 22rpx;
  color: #52525b;
}

.char-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #e4e4e7;
}

.char-name.dim {
  color: #52525b;
}

.link {
  font-size: 24rpx;
  color: #9333ea;
  margin-left: 16rpx;
}

.clear-link {
  font-size: 24rpx;
  color: #f87171;
}

/* 按钮 */
.btn {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.btn-active {
  background: #9333ea;
  color: #fff;
}

.btn-inactive {
  background: #27272a;
  color: #a1a1aa;
}

.btn-dim {
  background: #27272a;
  color: #52525b;
}

.btn-disabled {
  opacity: 0.5;
}

.btn-sm {
  width: 48rpx;
  height: 48rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 武器选择 */
.picker-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #27272a;
  border: 1rpx solid #3f3f46;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #d4d4d8;
}

.arrow {
  font-size: 20rpx;
  color: #71717a;
}

.refine-row {
  display: flex;
  gap: 8rpx;
}

/* 阈值筛选 */
.threshold-group {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.threshold-label {
  font-size: 24rpx;
  color: #a1a1aa;
}

.threshold-input {
  width: 96rpx;
  background: #27272a;
  border: 1rpx solid #3f3f46;
  border-radius: 8rpx;
  padding: 6rpx 12rpx;
  font-size: 24rpx;
  color: #d4d4d8;
  text-align: center;
}

.threshold-pct {
  font-size: 24rpx;
  color: #71717a;
}

.placeholder {
  color: #52525b;
}

/* 套装网格 */
.sonata-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.sonata-tag {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.sonata-active {
  background: #9333ea;
  color: #fff;
}

.sonata-inactive {
  background: #27272a;
  color: #a1a1aa;
}

/* 排除标签 */
.exclude-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.exclude-tag {
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  border-radius: 6rpx;
}

.exclude-active {
  background: #7f1d1d;
  color: #fca5a5;
}

.exclude-inactive {
  background: #27272a;
  color: #71717a;
}

/* 计算按钮 */
.calc-btn {
  width: 100%;
  background: #9333ea;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 0;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border: none;
}

.calc-btn::after {
  border: none;
}

.calc-btn-disabled {
  opacity: 0.5;
}

/* 进度条 */
.progress-section {
  margin-bottom: 32rpx;
}

.progress-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #a1a1aa;
}

.progress-time {
  font-size: 24rpx;
  color: #c084fc;
  font-family: monospace;
}

.progress-pct {
  font-size: 24rpx;
  color: #71717a;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #27272a;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #9333ea;
  border-radius: 6rpx;
  transition: width 0.2s;
}

/* 过滤警告 */
.filter-warning {
  text-align: center;
  padding: 32rpx;
  color: #fb923c;
  font-size: 28rpx;
}

/* 结果列表 */
.results {
  margin-top: 16rpx;
}

.results-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.results-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #d4d4d8;
}

.results-sub {
  font-size: 24rpx;
  color: #71717a;
}

.results-tag {
  font-size: 22rpx;
  color: #c084fc;
}

.results-filtered {
  font-size: 22rpx;
  color: #71717a;
}

/* 结果卡片 */
.result-card {
  background: #18181b;
  border: 1rpx solid #27272a;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.result-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.rank {
  font-size: 28rpx;
  font-weight: 500;
  color: #e4e4e7;
}

.score {
  font-size: 26rpx;
  color: #d4d4d8;
}

.grade {
  font-size: 26rpx;
  font-weight: 700;
}

.grade-SSS { color: #f87171; }
.grade-SS { color: #fb923c; }
.grade-S { color: #fbbf24; }
.grade-A { color: #c084fc; }
.grade-B { color: #60a5fa; }
.grade-C { color: #a1a1aa; }

.dmg {
  font-size: 24rpx;
  color: #fb923c;
  font-family: monospace;
}

.save-btn {
  margin-left: auto;
  font-size: 24rpx;
  background: #3f3f46;
  color: #d4d4d8;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
}

/* 结果统计 */
.result-stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.stat {
  font-size: 22rpx;
  color: #a1a1aa;
  font-family: monospace;
}

.stat-warn {
  color: #f87171;
}

.stat.dim {
  color: #52525b;
}

/* 声骸横向滚动 */
.echo-scroll {
  white-space: nowrap;
  margin: 0 -20rpx;
  padding: 0 20rpx;
}

.echo-row {
  display: inline-flex;
  gap: 12rpx;
}

.echo-mini {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
  padding: 8rpx 4rpx;
  background: #27272a;
  border-radius: 8rpx;
}

.echo-cost {
  font-size: 20rpx;
  font-weight: 600;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-bottom: 4rpx;
}

.echo-cost-1 { background: #3f3f46; color: #a1a1aa; }
.echo-cost-3 { background: #1e3a5f; color: #93c5fd; }
.echo-cost-4 { background: #4c1d95; color: #c4b5fd; }

.echo-name {
  font-size: 18rpx;
  color: #a1a1aa;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 112rpx;
  text-align: center;
}

.echo-score {
  font-size: 18rpx;
  color: #71717a;
  font-family: monospace;
}
