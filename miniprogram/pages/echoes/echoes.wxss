/* pages/echoes/echoes.wxss */

.page { min-height: 100vh; padding: 28rpx 24rpx 56rpx; background: #f4f6fb; }

.toolbar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
  flex-wrap: wrap;
}

.link {
  min-height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  color: #2563eb;
  background: #eff6ff;
  border-radius: 8rpx;
}

.link-danger { color: #b42318; background: #fff1f2; }
.link-guide { color: #475467; background: #f8fafc; border: 1rpx solid #dbe3ef; }

.import-msg {
  font-size: 24rpx;
  padding: 14rpx 18rpx;
  border-radius: 10rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e1e7f0;
}

.import-msg.success { color: #15803d; border-color: #bbf7d0; background: #f0fdf4; }
.import-msg.warn { color: #b54708; border-color: #fedf89; background: #fffbeb; }
.import-msg.error { color: #b42318; border-color: #fecdd3; background: #fff1f2; }

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(15, 23, 42, 0.38);
  padding: 24rpx;
  box-sizing: border-box;
}

.import-panel {
  width: 100%;
  max-height: 82vh;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 42rpx rgba(24, 32, 51, 0.16);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #182033;
  margin-bottom: 8rpx;
}

.modal-desc {
  font-size: 23rpx;
  line-height: 1.5;
  color: #667085;
  margin-bottom: 16rpx;
}

.json-textarea {
  width: 100%;
  min-height: 320rpx;
  padding: 16rpx;
  box-sizing: border-box;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #182033;
  line-height: 1.45;
}

.modal-actions {
  display: flex;
  gap: 10rpx;
  justify-content: flex-end;
  margin-top: 18rpx;
  flex-wrap: wrap;
}

.modal-btn {
  min-width: 132rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 9rpx;
  font-size: 24rpx;
}

.modal-btn.primary {
  color: #ffffff;
  background: #2563eb;
}

.modal-btn.secondary {
  color: #4b5565;
  background: #f1f5f9;
}

.form-card,
.filter-panel,
.echo-card {
  background: #ffffff;
  border: 1rpx solid #e1e7f0;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 22rpx rgba(24, 32, 51, 0.05);
}

.form-card { padding: 24rpx; margin-bottom: 22rpx; }
.form-title { font-size: 32rpx; font-weight: 700; color: #182033; display: block; margin-bottom: 18rpx; }
.form-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 14rpx; flex-wrap: wrap; }
.form-label { font-size: 24rpx; color: #667085; }

.input-name,
.input-value,
.input-sub,
.picker-btn,
.picker-btn-sm,
.filter-picker {
  min-height: 64rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  border-radius: 9rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  color: #182033;
}

.input-name { width: 220rpx; }
.input-value { width: 170rpx; }
.input-sub { width: 132rpx; text-align: center; }
.picker-btn { line-height: 64rpx; max-width: 420rpx; }
.picker-btn-sm { line-height: 64rpx; max-width: 310rpx; }

.cost-row,
.cost-filter-row,
.filter-row,
.sub-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.btn-sm {
  min-width: 58rpx;
  height: 58rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-active { background: #2563eb; color: #ffffff; }
.btn-inactive { background: #f1f5f9; color: #4b5565; }

.sub-section { margin-top: 14rpx; }
.sub-row { margin-top: 10rpx; }
.remove-btn { color: #b42318; font-size: 24rpx; padding: 8rpx 12rpx; }
.add-sub { display: inline-block; font-size: 24rpx; color: #2563eb; background: #eff6ff; padding: 10rpx 16rpx; border-radius: 8rpx; margin-top: 10rpx; }

.nightmare-hint {
  background: #f5f3ff;
  border: 1rpx solid #ddd6fe;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  font-size: 22rpx;
  color: #5b21b6;
  margin: 14rpx 0;
}

.submit-btn {
  min-height: 82rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 12rpx;
  border: none;
  margin-top: 16rpx;
}

.submit-btn::after { border: none; }

.filter-panel { padding: 18rpx; margin-bottom: 20rpx; }
.filter-label { font-size: 24rpx; color: #667085; font-weight: 600; }
.filter-picker { line-height: 60rpx; min-height: 60rpx; font-size: 22rpx; }

.checkbox-row { display: flex; align-items: center; gap: 8rpx; }
.checkbox { width: 30rpx; height: 30rpx; border: 1rpx solid #cbd5e1; border-radius: 6rpx; background: #ffffff; }
.checkbox-on { background: #2563eb; border-color: #2563eb; }
.checkbox-label { font-size: 22rpx; color: #4b5565; }
.filter-count { font-size: 22rpx; color: #7a8499; margin-left: auto; }

.echo-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.echo-card { width: calc((100% - 16rpx) / 2); padding: 18rpx; }

.echo-header { display: flex; align-items: center; gap: 8rpx; margin-bottom: 8rpx; }
.echo-cost { font-size: 20rpx; font-weight: 700; padding: 3rpx 10rpx; border-radius: 6rpx; }
.echo-cost-1 { background: #eef2f7; color: #526071; }
.echo-cost-3 { background: #dbeafe; color: #1d4ed8; }
.echo-cost-4 { background: #ede9fe; color: #5b21b6; }
.echo-name { font-size: 25rpx; color: #182033; font-weight: 700; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.echo-score { font-size: 20rpx; color: #667085; font-family: monospace; }
.echo-remove { font-size: 20rpx; color: #b42318; background: #fff1f2; padding: 4rpx 8rpx; border-radius: 6rpx; }

.echo-sonata { font-size: 21rpx; color: #7a8499; margin-bottom: 8rpx; }
.echo-main { font-size: 23rpx; color: #182033; margin-bottom: 5rpx; }
.echo-secondary { font-size: 21rpx; margin-bottom: 5rpx; }
.dim { color: #667085; }

.echo-subs { display: flex; flex-wrap: wrap; gap: 6rpx; margin-top: 8rpx; }
.sub-tag { font-size: 19rpx; background: #f1f5f9; color: #4b5565; padding: 4rpx 8rpx; border-radius: 6rpx; }
.echo-nightmare { font-size: 19rpx; color: #5b21b6; margin-top: 8rpx; }

.empty {
  text-align: center;
  padding: 96rpx 0;
  color: #7a8499;
  font-size: 28rpx;
}
