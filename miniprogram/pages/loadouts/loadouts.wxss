/* pages/loadouts/loadouts.wxss */

.page { min-height: 100vh; padding: 28rpx 24rpx 56rpx; background: #f4f6fb; }

.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 22rpx;
  padding: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e1e7f0;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 22rpx rgba(24, 32, 51, 0.05);
}

.title { font-size: 32rpx; font-weight: 700; color: #182033; }
.filter-picker,
.weapon-picker {
  min-height: 60rpx;
  line-height: 60rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  border-radius: 9rpx;
  padding: 0 16rpx;
  font-size: 23rpx;
  color: #182033;
}

.empty { text-align: center; padding: 96rpx 0; color: #7a8499; font-size: 28rpx; }

.loadout-card,
.stat-card,
.modal-content {
  background: #ffffff;
  border: 1rpx solid #e1e7f0;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 22rpx rgba(24, 32, 51, 0.05);
}

.loadout-card { padding: 22rpx; margin-bottom: 18rpx; }

.card-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.name-row { min-height: 52rpx; display: flex; align-items: center; }
.loadout-name { font-size: 29rpx; font-weight: 700; color: #182033; }
.edit-row { flex: 1; min-width: 260rpx; }
.edit-input { height: 64rpx; background: #f8fafc; border: 1rpx solid #dbe3ef; border-radius: 9rpx; padding: 0 14rpx; font-size: 26rpx; color: #182033; }

.char-label,
.score-label {
  font-size: 23rpx;
  padding: 6rpx 10rpx;
  border-radius: 6rpx;
}

.char-label { color: #2563eb; background: #eff6ff; }
.score-label { color: #3f4b5f; background: #f1f5f9; }

.grade { font-size: 26rpx; font-weight: 800; }
.grade-SSS { color: #be123c; } .grade-SS { color: #ea580c; } .grade-S { color: #ca8a04; }
.grade-A { color: #2563eb; } .grade-B { color: #0891b2; } .grade-C { color: #7a8499; }

.dmg-toggle,
.delete-btn,
.clear-link {
  min-height: 48rpx;
  line-height: 48rpx;
  font-size: 22rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
}

.dmg-toggle { color: #2563eb; background: #eff6ff; }
.delete-btn { color: #b42318; background: #fff1f2; margin-left: auto; }
.clear-link { color: #b42318; background: #fff1f2; }

.echo-scroll { white-space: nowrap; margin: 0 -22rpx; padding: 0 22rpx; }
.echo-row { display: inline-flex; gap: 12rpx; }
.echo-slot { display: inline-block; position: relative; width: 210rpx; }
.echo-card { background: #f8fafc; border: 1rpx solid #e4e9f2; border-radius: 10rpx; padding: 14rpx; min-height: 164rpx; }

.echo-header { display: flex; align-items: center; gap: 6rpx; margin-bottom: 8rpx; }
.echo-cost { font-size: 18rpx; font-weight: 700; padding: 3rpx 8rpx; border-radius: 6rpx; }
.echo-cost-1 { background: #eef2f7; color: #526071; }
.echo-cost-3 { background: #dbeafe; color: #1d4ed8; }
.echo-cost-4 { background: #ede9fe; color: #5b21b6; }
.echo-name { font-size: 21rpx; color: #182033; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1; font-weight: 700; }
.echo-sonata { font-size: 18rpx; color: #7a8499; margin-bottom: 5rpx; }
.echo-main { font-size: 20rpx; color: #3f4b5f; margin-bottom: 5rpx; }
.echo-subs { display: flex; flex-wrap: wrap; gap: 4rpx; }
.sub-tag { font-size: 16rpx; background: #eef2f7; color: #4b5565; padding: 3rpx 6rpx; border-radius: 5rpx; }

.replace-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: rgba(37, 99, 235, 0.92);
  color: #ffffff;
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.damage-panel { border-top: 1rpx solid #e4e9f2; padding-top: 18rpx; margin-top: 18rpx; }
.panel-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 12rpx; flex-wrap: wrap; }
.panel-label { font-size: 22rpx; color: #667085; font-weight: 600; }

.btn-sm {
  min-width: 50rpx;
  height: 50rpx;
  padding: 0 12rpx;
  font-size: 22rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-active { background: #2563eb; color: #ffffff; }
.btn-inactive { background: #f1f5f9; color: #4b5565; }
.btn-dim { background: #f1f5f9; color: #98a2b3; }
.refine-row { display: flex; gap: 6rpx; flex-wrap: wrap; }

.stat-grid { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 16rpx; }
.stat-card { width: calc((100% - 20rpx) / 3); padding: 12rpx; text-align: center; box-shadow: none; }
.stat-label { font-size: 20rpx; color: #7a8499; display: block; }
.stat-value { font-size: 26rpx; font-weight: 700; color: #182033; display: block; margin-top: 4rpx; }

.dmg-table { font-size: 22rpx; overflow: hidden; border: 1rpx solid #e4e9f2; border-radius: 10rpx; }
.dmg-thead,
.dmg-row,
.dmg-footer { display: flex; align-items: center; }
.dmg-thead { background: #f8fafc; padding: 10rpx 8rpx; }
.dmg-row { padding: 10rpx 8rpx; border-top: 1rpx solid #edf2f7; }
.dmg-th { color: #667085; font-weight: 600; }
.dmg-td { color: #3f4b5f; }
.dmg-th-name, .dmg-td-name { flex: 2; min-width: 0; }
.dmg-th-tag, .dmg-td-tag { width: 76rpx; text-align: center; }
.dmg-th-right, .dmg-td-right { width: 112rpx; text-align: right; }
.dmg-td-expected { color: #182033; font-family: monospace; }
.dmg-td-crit { color: #b54708; font-family: monospace; }

.tag { font-size: 18rpx; padding: 3rpx 8rpx; border-radius: 5rpx; }
.tag-E { background: #dbeafe; color: #1d4ed8; }
.tag-Q { background: #ffedd5; color: #c2410c; }
.tag-变奏 { background: #dcfce7; color: #166534; }

.dmg-footer { justify-content: space-between; border-top: 1rpx solid #dbe3ef; padding: 12rpx; background: #f8fafc; }
.dmg-footer-label { font-size: 22rpx; color: #667085; }
.dmg-footer-value { font-size: 24rpx; color: #182033; font-family: monospace; font-weight: 700; }

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.46);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.modal-content { padding: 24rpx; width: 100%; max-height: 80vh; }
.modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.modal-title { font-size: 28rpx; font-weight: 700; color: #182033; }
.modal-close { font-size: 28rpx; color: #7a8499; padding: 8rpx; }
.modal-filter { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; flex-wrap: wrap; }
.modal-count { font-size: 22rpx; color: #7a8499; }
.modal-empty { text-align: center; padding: 42rpx; color: #7a8499; font-size: 24rpx; }
.modal-list { max-height: 60vh; }
.modal-echo-card { background: #f8fafc; border: 1rpx solid #e4e9f2; border-radius: 10rpx; padding: 16rpx; margin-bottom: 12rpx; }
.echo-score { font-size: 20rpx; color: #667085; font-family: monospace; }
