/* components/echo-card/echo-card.wxss */

.echo-card {
  background: #ffffff;
  border: 1rpx solid #e1e7f0;
  border-radius: 12rpx;
  padding: 18rpx;
  box-shadow: 0 8rpx 22rpx rgba(24, 32, 51, 0.05);
}

.card-top {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.cost {
  font-size: 20rpx;
  font-weight: 700;
  padding: 3rpx 10rpx;
  border-radius: 6rpx;
}

.cost-1 { background: #eef2f7; color: #526071; }
.cost-3 { background: #dbeafe; color: #1d4ed8; }
.cost-4 { background: #ede9fe; color: #5b21b6; }

.name {
  font-size: 25rpx;
  color: #182033;
  font-weight: 700;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.score {
  font-size: 22rpx;
  font-family: monospace;
  color: #3f4b5f;
}

.grade {
  font-size: 22rpx;
  font-weight: 800;
}

.g-sss { color: #be123c; }
.g-ss { color: #ea580c; }
.g-s { color: #ca8a04; }
.g-a { color: #2563eb; }
.g-b { color: #0891b2; }
.g-c { color: #7a8499; }

.sonata {
  font-size: 21rpx;
  color: #7a8499;
  margin-bottom: 8rpx;
}

.main-stat {
  font-size: 23rpx;
  color: #182033;
  margin-bottom: 5rpx;
}

.sec-stat {
  font-size: 21rpx;
  margin-bottom: 5rpx;
}

.dim { color: #667085; }

.subs {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-top: 8rpx;
}

.sub-tag {
  font-size: 19rpx;
  background: #f1f5f9;
  color: #4b5565;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
}

.nightmare {
  font-size: 19rpx;
  color: #5b21b6;
  margin-top: 10rpx;
  background: #f5f3ff;
  border: 1rpx solid #ddd6fe;
  border-radius: 8rpx;
  padding: 8rpx 10rpx;
}

.detail-row {
  margin-bottom: 10rpx;
}

.detail-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
  gap: 8rpx;
}

.detail-field,
.detail-label,
.detail-score {
  font-size: 20rpx;
}

.detail-field { color: #7a8499; }
.detail-label { color: #3f4b5f; }
.detail-score { font-family: monospace; }

.score-high { color: #be123c; }
.score-mid { color: #ea580c; }
.score-low { color: #3f4b5f; }
.score-max { color: #98a2b3; }

.detail-bar {
  width: 100%;
  height: 8rpx;
  background: #e8edf5;
  border-radius: 999rpx;
  overflow: hidden;
}

.detail-bar-fill {
  height: 100%;
  border-radius: 999rpx;
}

.bar-high { background: #dc2626; }
.bar-mid { background: #f97316; }
.bar-low { background: #94a3b8; }

.detail-footer {
  display: flex;
  justify-content: space-between;
  border-top: 1rpx solid #e4e9f2;
  padding-top: 10rpx;
  margin-top: 8rpx;
  gap: 8rpx;
}

.footer-label {
  font-size: 20rpx;
  color: #667085;
}

.footer-total {
  font-size: 22rpx;
  color: #182033;
  font-family: monospace;
  font-weight: 700;
}

.footer-max {
  font-size: 18rpx;
  color: #98a2b3;
}
